# HTTP サーバー
HTTP_HOST=0.0.0.0
HTTP_PORT=3000

# GitHub Actions から送られる HMAC-SHA256 署名検証用の共有シークレット
# Actions の secrets.CODEX_REVIEW_SECRET と必ず同じ値にする
WEBHOOK_SECRET=change-me-to-a-long-random-string

# GitHub App 認証 (必須)
# https://github.com/settings/apps で Private App を作成
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=/app/github-app-key.pem
GITHUB_APP_INSTALLATION_ID=

# Discord Bot Token (Bot を作成して取得 / Message Content Intent を有効化)
DISCORD_BOT_TOKEN=
# レビューを投稿するチャンネル ID
DISCORD_CHANNEL_ID=

# codex CLI 実行設定
CODEX_BIN=codex
# codex exec に渡す追加引数 (例: --model gpt-5-codex --full-auto)
CODEX_EXTRA_ARGS=
# codex 1 回あたりの最大実行時間 (ms)
CODEX_TIMEOUT_MS=900000

# shutdown 時に queue.drain を待つ最大時間 (ms)。超過時は warn ログを出して強制終了
SHUTDOWN_TIMEOUT_MS=30000

# 作業用ディレクトリ (clone 先)
WORKSPACES_DIR=/app/workspaces
# SQLite データディレクトリ
DATA_DIR=/app/data

# ログレベル: trace | debug | info | warn | error
LOG_LEVEL=info

# config ファイルのパス
CONFIG_FILE=/app/config.yml
